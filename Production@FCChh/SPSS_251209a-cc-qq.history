# ----- Model -----
import model SPSS_251209a-m

define p  = g d d~ u u~ s s~ c c~ b b~
define j  = g d d~ u u~ s s~ c c~ b b~
define qq = u u~ c c~ d d~ s s~ b b~

define uu = u u~
define cc = c c~
define tt = t t~
define dd = d d~
define ss = s s~
define bb = b b~

define l- = mu-
define l+ = mu+
define ll = mu+ mu-
define v  = vm
define v~ = vm~
define vv = vm vm~

define ee  = e+ e-
define vee = ve ve~
define mu  = mu+ mu-
define vmu = vm vm~
define ta  = ta+ ta-
define vta = vt vt~

define ww = w+ w-

define nn = n1 n2

# ----- Simulation -----
generate    p p > nn ll

output Production@FCChh/SPSS_251209a-cc-qq.run

launch Production@FCChh/SPSS_251209a-cc-qq.run

shower=OFF
detector=OFF
analysis=OFF
madspin=OFF

done

